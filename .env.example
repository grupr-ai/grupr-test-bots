# Copy to .env (gitignored) and fill in real values.
#
# Personas are LLM-driven agents (Sonnet 4.6 with tool use) exploring
# api.grupr.ai with a goal + tools, NOT scripted step-walkers.
ANTHROPIC_API_KEY=

# Base URL of the api under test.
GRUPR_API_BASE=https://api.grupr.ai

# The test accounts are pre-seeded via scripts/seed-test-accounts.sh
# (one-shot via SSH against the EC2 DB). Personas log in with these —
# signup is intentionally OUT OF SCOPE for the LLM personas because
# Cloudflare Turnstile (Day-2 follow-up #1) now gates /register and
# can't be passed without a real browser. Signup is covered by a
# separate manual / Playwright smoke.
#
# Shared password across all seeded accounts.
GRUPR_TEST_PASSWORD=test-bot-password-2026

# Per-persona email addresses. These match the rows seeded by the
# seed script. Override locally if you change the seed pattern.
GRUPR_TEST_NEW_USER_EMAIL=bret.babcock+gtb-newuser@gmail.com
GRUPR_TEST_POWER_USER_EMAIL=bret.babcock+gtb-poweruser@gmail.com
GRUPR_TEST_EXTERNAL_DEV_EMAIL=bret.babcock+gtb-externaldev@gmail.com
GRUPR_TEST_ADMIN_EMAIL=bret.babcock+gtb-admin@gmail.com
GRUPR_TEST_ADVERSARY_EMAIL=bret.babcock+gtb-adversary@gmail.com
GRUPR_TEST_CONV_A_EMAIL=bret.babcock+gtb-conv-a@gmail.com
GRUPR_TEST_CONV_B_EMAIL=bret.babcock+gtb-conv-b@gmail.com
GRUPR_TEST_CONV_C_EMAIL=bret.babcock+gtb-conv-c@gmail.com

# Anthropic model used by all personas. Sonnet 4.6 is the cost-perf
# sweet spot per the launch plan.
GRUPR_TEST_MODEL=claude-sonnet-4-5-20250929

# Hard cap per persona run, in USD. Persona runner exits cleanly
# when this is hit. Sized for typical multi-turn agent runs.
GRUPR_TEST_MAX_COST_USD=5.0

# Hard cap on tool-using turns per persona. Prevents runaway loops.
GRUPR_TEST_MAX_TURNS=40
